# HTTP service
PORT=3100

# Repository driver: sqlite (default) or memory
REPOSITORY_DRIVER=sqlite

# Two physical databases for MVP:
# 1) hotel catalog
HOTEL_CATALOG_DB_PATH=/srv/hotel-review-intelligence/data/runtime/hotel_catalog.sqlite
# 2) review intelligence
REVIEW_INTELLIGENCE_DB_PATH=/srv/hotel-review-intelligence/data/runtime/review_intelligence.sqlite

# Runtime stores
RUNTIME_STORE_PATH=/srv/hotel-review-intelligence/.runtime-store.json
HOTEL_SEARCH_CACHE_PATH=/srv/hotel-review-intelligence/.hotel-search-cache.json
HOTEL_SEARCH_CACHE_LIMIT=120000
HOTEL_SEARCH_CACHE_MEMORY_TTL_MS=60000
HOTEL_SEARCH_INCLUDE_SEED=0

# National hotel catalog source
RUSSIA_HOTELS_CATALOG_PATH=/srv/hotel-review-intelligence/data/russia-hotels-catalog.json
RUSSIA_HOTELS_IMPORT_LIMIT=120000

# Protected sync endpoints
SYNC_TRIGGER_TOKEN=replace_with_long_random_token

# Optional: build fallback sync targets for any newly added hotel
# If datasetUrl is omitted, runtime collector (Apify) must be configured.
DEFAULT_REALTIME_TARGETS_JSON=[{"provider":"yandex_maps_dataset","query":"{hotelName} {city}","limit":500},{"provider":"two_gis_dataset","query":"{hotelName} {city}","limit":500},{"provider":"ostrovok_dataset","query":"{hotelName} {city}","limit":500}]
PORTFOLIO_SYNC_INCLUDE_FALLBACK_UNCOVERED=true

# Optional: explicit portfolio targets for selected hotels
# PORTFOLIO_SYNC_TARGETS_JSON=[{"hotelName":"Courtyard by Marriott Rostov-on-Don","provider":"yandex_maps_dataset","query":"{hotelName} {city}","limit":700}]

# Runtime collector via Apify actor mode
APIFY_TOKEN=replace_with_apify_token
APIFY_ACTOR_YANDEX_MAPS=your-actor-id-or-username~actor-name
APIFY_ACTOR_TWO_GIS=your-actor-id-or-username~actor-name
APIFY_ACTOR_OSTROVOK=your-actor-id-or-username~actor-name
APIFY_ACTOR_RUSSIAN_TRAVEL=
APIFY_ACTOR_DEFAULT=
APIFY_ACTOR_TIMEOUT_MS=480000

# Optional actor input templates (JSON)
# APIFY_ACTOR_INPUT_TEMPLATE_YANDEX_MAPS={"query":"{query}","maxItems":"{limit}","language":"{language}"}
# APIFY_ACTOR_INPUT_TEMPLATE_TWO_GIS={"query":"{query}","maxItems":"{limit}","language":"{language}"}
# APIFY_ACTOR_INPUT_TEMPLATE_OSTROVOK={"query":"{query}","maxItems":"{limit}","language":"{language}"}

# Optional: official search API keys (for external profile resolver layer)
YANDEX_GEOSUGGEST_API_KEY=
YANDEX_GEOSEARCH_API_KEY=
TWO_GIS_API_KEY=
